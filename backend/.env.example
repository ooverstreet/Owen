# ── App Security ─────────────────────────────────────────────────
# Password that protects your bot — set this to something strong
APP_TOKEN=change_this_to_a_strong_password

# ── Paper Trading (START HERE — no real money) ───────────────────
PAPER_MODE=true
PAPER_BALANCE=1000
# Keep auto-trading enabled after backend restarts/redeploys
TRADING_ENABLED_ON_STARTUP=true

# ── Trade Settings ────────────────────────────────────────────────
# How much USD to risk per trade
TRADE_SIZE=50

# Optional dynamic sizing (percent of available balance)
# 0 disables percentage sizing and uses TRADE_SIZE fixed USD.
TRADE_SIZE_PCT=0
TRADE_SIZE_MIN_USD=0
TRADE_SIZE_MAX_USD=0

# Maximum open positions at once (recommended: 2)
MAX_POSITIONS=2

# Stop auto-trading if daily losses exceed this amount (USD)
DAILY_LOSS_LIMIT=50

# Timeframe for signals: 1m | 5m | 15m | 1h | 4h
# 15m is recommended for automated trading (less noise than 1m/5m)
TIMEFRAME=15m

# Coins to watch (comma-separated Coinbase product IDs)
WATCHED_COINS=BTC-USD,ETH-USD,SOL-USD

# ── Active Mode (more frequent entries) ───────────────────────────
# true  = enters on BUY/SELL/STRONG_* when confidence threshold is met
# false = enters only on STRONG_BUY / STRONG_SELL
ACTIVE_MODE=true

# Minimum signal confidence (0-100) required to open a position in ACTIVE_MODE
MIN_CONFIDENCE=35

# Score thresholds for turning model score into BUY/SELL labels
# Lower values = fewer HOLD labels and more trades
BUY_SCORE_THRESHOLD=0.28
STRONG_SCORE_THRESHOLD=0.55

# Optional dip-buy/rally-sell filter (for pullback entries)
# true = require a minimum pullback (BUY) / rally (SELL) over recent candles
DIP_BUY_ENABLED=false
DIP_LOOKBACK_CANDLES=6
MIN_DIP_PCT=0.25

# Ensure each trade's TP is at least this USD target relative to TRADE_SIZE
MIN_TAKE_PROFIT_USD=0

# Minimum unrealized USD profit required before SIGNAL_REVERSAL close is allowed
# Stop-loss and take-profit exits still work regardless of this setting.
SIGNAL_CLOSE_MIN_PROFIT_USD=0

# Paper-mode testing option: disable stop-loss exits (higher risk, test only)
PAPER_DISABLE_STOP_LOSS=false

# Per-coin cooldown between new entries (minutes)
ENTRY_COOLDOWN_MIN=8

# Regime filter (recommended): skip choppy/low-volatility entries
REGIME_FILTER=true

# Minimum EMA spread as % of price for an entry
MIN_EMA_GAP_PCT=0.12

# Minimum ATR(14) as % of price for an entry
MIN_ATR_PCT=0.35

# Require BUY/SELL to match EMA trend direction when regime filter is enabled
REGIME_REQUIRE_EMA_ALIGNMENT=true

# Higher-timeframe trend confirmation (recommended for robustness)
HTF_FILTER_ENABLED=false
# Timeframe used for trend confirmation: 15m | 1h | 4h
HTF_TIMEFRAME=1h
# Require side direction to match HTF EMA trend
HTF_REQUIRE_EMA_ALIGNMENT=true
# For BUY entries, require HTF RSI >= this value (set 0 to disable RSI gate)
HTF_MIN_RSI=50

# In paper mode, set true to block new SELL entries (long-only test mode)
LONG_ONLY_PAPER=false

# In live mode, keep this true for spot-only behavior (no fresh SELL entries)
LONG_ONLY_LIVE=true

# ── Wallet signal overlay (Phase 1 scaffold) ─────────────────────
# Enable wallet-flow gating (requires posting flow data to /api/wallet-signals)
WALLET_SIGNAL_ENABLED=false
# off|filter|boost (phase-1 uses filter semantics in entry gating)
WALLET_SIGNAL_MODE=off
# Minimum wallet score required for directional entries
WALLET_SIGNAL_THRESHOLD=0.2
# Optional confidence boost % applied when wallet gate passes (future use)
WALLET_SIGNAL_BOOST_PCT=20

# ── Execution realism + faster loop ────────────────────────────────
# Fee model in basis points (e.g., 10 = 0.10% each side)
FEE_BPS=10
# Slippage assumptions in basis points
SLIPPAGE_BPS_ENTRY=3
SLIPPAGE_BPS_EXIT=3
# Enable ATR-based trailing stop updates on open positions
ATR_TRAIL_ENABLED=true
# Trail distance = ATR% at entry * this multiplier
ATR_TRAIL_MULT=1.2
# Arm break-even stop once trade reaches this R multiple
BREAK_EVEN_TRIGGER_R=0.6
# Break-even stop offset in basis points past entry
BREAK_EVEN_OFFSET_BPS=2
# Monitor loop interval (seconds). Lower = faster reactions, more API calls.
LOOP_INTERVAL_SEC=60

# ── Coinbase API (only needed when PAPER_MODE=false) ─────────────
# Get your API key from: coinbase.com → Advanced Trade → Settings → API
# IMPORTANT: Grant View + Trade permissions only. NEVER grant Withdraw.
#
# New CDP format (the "long" key):
CB_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
#
# Paste your private key — replace actual newlines with \n
CB_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END EC PRIVATE KEY-----
