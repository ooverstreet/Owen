# ── App Security ─────────────────────────────────────────────────
# Password that protects your bot — set this to something strong
APP_TOKEN=change_this_to_a_strong_password

# ── Paper Trading (START HERE — no real money) ───────────────────
PAPER_MODE=true
PAPER_BALANCE=1000

# ── Trade Settings ────────────────────────────────────────────────
# How much USD to risk per trade
TRADE_SIZE=50

# Maximum open positions at once (recommended: 2)
MAX_POSITIONS=2

# Stop auto-trading if daily losses exceed this amount (USD)
DAILY_LOSS_LIMIT=50

# Timeframe for signals: 1m | 5m | 15m | 1h | 4h
# 15m is recommended for automated trading (less noise than 1m/5m)
TIMEFRAME=15m

# Coins to watch (comma-separated Coinbase product IDs)
WATCHED_COINS=BTC-USD,ETH-USD,SOL-USD

# ── Active Mode (more frequent entries) ───────────────────────────
# true  = enters on BUY/SELL/STRONG_* when confidence threshold is met
# false = enters only on STRONG_BUY / STRONG_SELL
ACTIVE_MODE=true

# Minimum signal confidence (0-100) required to open a position in ACTIVE_MODE
MIN_CONFIDENCE=35

# Per-coin cooldown between new entries (minutes)
ENTRY_COOLDOWN_MIN=8

# Regime filter (recommended): skip choppy/low-volatility entries
REGIME_FILTER=true

# Minimum EMA spread as % of price for an entry
MIN_EMA_GAP_PCT=0.12

# Minimum ATR(14) as % of price for an entry
MIN_ATR_PCT=0.35

# In live mode, keep this true for spot-only behavior (no fresh SELL entries)
LONG_ONLY_LIVE=true

# ── Coinbase API (only needed when PAPER_MODE=false) ─────────────
# Get your API key from: coinbase.com → Advanced Trade → Settings → API
# IMPORTANT: Grant View + Trade permissions only. NEVER grant Withdraw.
#
# New CDP format (the "long" key):
CB_KEY_NAME=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
#
# Paste your private key — replace actual newlines with \n
CB_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_CONTENT_HERE\n-----END EC PRIVATE KEY-----
